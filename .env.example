# Anthropic API key — required for cloud reasoning calls
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Poe API key — optional, enables additional model tier (Haiku, GPT-4o-mini, etc.)
# Get yours at https://poe.com/api_key
# POE_API_KEY=your-poe-key-here

# Daily API budget ceiling in USD (default: 4.00)
# DAILY_BUDGET_USD=4.00

# Set to "true" to run entirely on local models (no API costs, slower reasoning)
# FREE_TIER_MODE=false
